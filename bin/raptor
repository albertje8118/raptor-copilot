#!/usr/bin/env bash
#
# raptor — launch RAPTOR via GitHub Copilot CLI
#
# Install: add this directory to PATH, or symlink to a directory already on PATH.
#

set -euo pipefail

# Resolve symlinks to find the real script location
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
    DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
    SCRIPT="$(readlink "$SCRIPT")"
    [[ "$SCRIPT" != /* ]] && SCRIPT="$DIR/$SCRIPT"
done
RAPTOR_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

# --- Usage ---

usage() {
    cat <<'EOF'
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣠⣤⣤⣀⣀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣾⣿⣿⠿⠿⠟
⠀⠀⠀⠀⠀⠀⠀⠀⢀⣀⣀⣀⣀⣀⣀⣤⣴⣶⣶⣶⣤⣿⡿⠁
⣀⠤⠴⠒⠒⠛⠛⠛⠛⠛⠿⢿⣿⣿⣿⣿⣿⣿⣿⣿⣿⠟⠁
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠛⣿⣿⣿⡟⠻⢿⡀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣾⢿⣿⠟⠀⠸⣊⡽
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢸⡇⣿⡁⠀⠀⠀⠉⠁
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠈⠻⠿⣿⣧

Usage: raptor [options] [target]

Arguments:
  target             Path or URL to scan (optional)

Options:
  -m, --model MODEL  Choose model (gpt-5.4, claude-sonnet-4.6)
  -h, --help         Show this help

Any additional flags are passed through to copilot.
EOF
    exit 0
}

# --- Parse args ---

COPILOT_ARGS=()
INITIAL_PROMPT="/raptor"
TARGET=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        -m|--model)
            [[ $# -ge 2 ]] || { echo "  -m requires a model name"; exit 1; }
            COPILOT_ARGS+=(--model "$2")
            shift 2
            ;;
        -*)
            COPILOT_ARGS+=("$1")
            shift
            ;;
        *)
            TARGET="${TARGET:+$TARGET }$1"
            shift
            ;;
    esac
done

if [ -n "$TARGET" ] && [ -n "$INITIAL_PROMPT" ]; then
    INITIAL_PROMPT="/raptor $TARGET"
fi

# --- Prerequisites ---

if ! command -v copilot >/dev/null 2>&1; then
    echo "  copilot not found on PATH. Install GitHub Copilot CLI first."
    echo "  https://docs.github.com/en/copilot/how-tos/copilot-cli/cli-getting-started"
    exit 1
fi

if [ ! -d "$RAPTOR_DIR" ]; then
    echo "  RAPTOR directory not found: $RAPTOR_DIR"
    exit 1
fi

# --- Launch ---

cd "$RAPTOR_DIR"
if [ -n "$INITIAL_PROMPT" ]; then
    exec copilot "$INITIAL_PROMPT" "${COPILOT_ARGS[@]}"
else
    exec copilot "${COPILOT_ARGS[@]}"
fi
